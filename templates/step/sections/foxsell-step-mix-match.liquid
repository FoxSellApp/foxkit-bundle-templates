{% style %}
  .foxsell-mix-match-section {
    background-color: {{ section.settings.section_background }};
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }

  @media screen and (min-width: 768px) {
    .foxsell-mix-match-section {
      padding-top: calc({{ section.settings.section_padding_top }}px * 1.5);
      padding-bottom: calc({{ section.settings.section_padding_bottom }}px * 1.5);
    }
  }
{% endstyle %}

{% liquid
  assign bundle_product = section.settings.bundle_product | default: product
%}

<div class="foxsell-mix-match-wrapper">
  {% render 'foxsell-step-mix-match', product: bundle_product, section: section %}
</div>

{% schema %}
{
  "name": "Foxsell M&M Step",
  "class": "foxsell-mix-match-section",
  "settings": [
    {
      "type": "product",
      "id": "bundle_product",
      "label": "Bundle product"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#F5F5F5"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "default": 48,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "default": 48,
      "min": 0,
      "max": 100,
      "step": 1
    },

    {
      "type": "header",
      "content": "Color scheme"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#FFFFFF",
      "info": "Product cards and bundle summary"
    },
    {
      "type": "color",
      "id": "text",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_1",
      "label": "Accent 1",
      "default": "#89CCA0"
    },
    {
      "type": "color",
      "id": "accent_text_1",
      "label": "Accent 1 text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent_2",
      "label": "Accent 2",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_text_2",
      "label": "Accent 2 text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border",
      "label": "Border",
      "default": "#E0E0E0"
    },
    {
      "type": "header",
      "content": "Border radius"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card",
      "default": 5,
      "min": 0,
      "max": 25,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button",
      "default": 5,
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "number",
      "id": "base_font_size",
      "label": "Base font size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Product Grid"
    },
    {
      "type": "range",
      "id": "product_grid_columns_desktop",
      "label": "Columns",
      "default": 3,
      "min": 1,
      "max": 5,
      "step": 1
    },
    {
      "type": "select",
      "id": "product_grid_columns_mobile",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "header",
      "content": "Category Heading"
    },
    {
      "type": "inline_richtext",
      "id": "category_heading_selected_text",
      "label": "Selected text",
      "default": "Selected $ products",
      "info": "Use $ as a placeholder for the selected product count"
    },
    {
      "type": "header",
      "content": "Bundle Summary"
    },
    {
      "type": "text",
      "id": "summary_title",
      "label": "Title",
      "default": "Bundle Summary"
    },
    {
      "type": "text",
      "id": "summary_price_label",
      "label": "Price label",
      "default": "Price"
    },
    {
      "type": "inline_richtext",
      "id": "summary_empty_state_text",
      "label": "Empty state text",
      "default": "Select _remainingQuantity product(s) to get _discount off",
      "info": "Use _remainingQuantity for the remaining quantity and _discount for the discount [Learn More](https://shopify.dev/docs)"
    },
    {
      "type": "inline_richtext",
      "id": "summary_progress_state_text",
      "label": "Progress state text",
      "default": "Select _remainingQuantity more product(s) to get _discount off",
      "info": "Use _currentQuantity for the current quantity and _requiredQuantity for the required quantity [Learn More](https://shopify.dev/docs)"
    },
    {
      "type": "inline_richtext",
      "id": "summary_end_state_text",
      "label": "End state text",
      "default": "Yay! bundle complete"
    },
    {
      "type": "text",
      "id": "summary_items_list_empty_text",
      "label": "Items list empty text",
      "default": "No items in bundle. Add items to your bundle to see the summary here."
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "text",
      "id": "label_add_ons",
      "label": "Add-ons",
      "default": "Add-ons"
    },
    {
      "type": "text",
      "id": "label_close",
      "label": "Close",
      "default": "close"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_show",
      "label": "Show",
      "default": "Show"
    },
    {
      "type": "text",
      "id": "button_hide",
      "label": "Hide",
      "default": "Hide"
    },
    {
      "type": "text",
      "id": "button_continue",
      "label": "Continue",
      "default": "Continue"
    },
    {
      "type": "text",
      "id": "button_go_back",
      "label": "Go back",
      "default": "Go Back"
    },
    {
      "type": "text",
      "id": "button_add",
      "label": "Add",
      "default": "Add"
    },
    {
      "type": "text",
      "id": "button_add_to_cart",
      "label": "Add to cart",
      "default": "Add to Cart"
    }
  ],
  "presets": [
    {
      "name": "Foxsell M&M Step",
      "settings": {
        "bundle_product": "{{ product }}"
      }
    }
  ]
}
{% endschema %}
