{% liquid
  assign app_namespace = 'app--67872686081'
  assign bundle_product = section.settings.bundle_product
  assign dynamic_add_ons_bundle_config = bundle_product.metafields[app_namespace].dynamic_add_ons_bundle.value
  assign use_wrapper_class = section.settings.section_padding_use_wrapper_class | default: false
%}

{% if dynamic_add_ons_bundle_config %}
  {% style %}
    .foxsell-mix-match-section {
      background-color: {{ section.settings.section_background | default: '#F5F5F5' }};
      padding-top: {{ section.settings.section_padding_top | default: 28 }}px;
      padding-bottom: {{ section.settings.section_padding_bottom | default: 28 }}px;
      {% unless use_wrapper_class %}padding-inline: {{ section.settings.section_padding_sides_mobile | default: 16 }}px;{% endunless %}
    }

    @media screen and (min-width: 768px) {
      .foxsell-mix-match-section {
        padding-top: calc({{ section.settings.section_padding_top | default: 28 }}px * 1.5);
        padding-bottom: calc({{ section.settings.section_padding_bottom | default: 28 }}px * 1.5);
        {% unless use_wrapper_class %}padding-inline: {{ section.settings.section_padding_sides_desktop | default: 40 }}px;{% endunless %}
      }
    }
  {% endstyle %}

  {% liquid
    assign wrapper_classes = 'foxsell-mix-match-wrapper'
    if use_wrapper_class and section.settings.wrapper_custom_classes != blank
      assign wrapper_classes = wrapper_classes | append: ' ' | append: section.settings.wrapper_custom_classes | strip
    endif
  %}
  <div class="{{ wrapper_classes }}">
    {% render 'foxsell-step-mix-match', product: bundle_product, section: section %}
  </div>
{% endif %}

{% schema %}
{
  "name": "FoxSell Step",
  "class": "foxsell-mix-match-section",
  "settings": [
