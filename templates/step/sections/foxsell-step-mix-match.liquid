    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "default": 28,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "default": 28,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "section_padding_sides_mobile",
