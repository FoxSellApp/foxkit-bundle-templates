{% render 'foxsell-skeleton-mix-match', product: product, section: section %}

{% schema %}
{
  "name": "Foxsell M&M Skeleton",
  "settings": [
    {
      "type": "header",
      "content": "Product Grid Settings"
    },
    {
      "type": "range",
      "id": "product_grid_columns_mobile",
      "label": "Columns (mobile)",
      "default": 1,
      "min": 1,
      "max": 3,
      "step": 1
    },
    {
      "type": "range",
      "id": "product_grid_columns_desktop",
      "label": "Columns (desktop)",
      "default": 3,
      "min": 1,
      "max": 5,
      "step": 1
    },
    {
      "type": "header",
      "content": "Product Card Settings"
    },
    {
      "type": "select",
      "id": "product_card_options_type",
      "label": "Variant Style",
      "options": [
        {
          "value": "radio",
          "label": "Radio"
        },
        {
          "value": "select",
          "label": "Select"
        }
      ],
      "default": "radio"
    },
    {
      "type": "header",
      "content": "Summary Settings"
    },
    {
      "type": "text",
      "id": "summary_title",
      "label": "Title",
      "default": "Bundle Summary"
    },
    {
      "type": "inline_richtext",
      "id": "summary_empty_state_text",
      "label": "Empty state text",
      "default": "No items in the bundle yet"
    },
    {
      "type": "inline_richtext",
      "id": "summary_progress_state_text",
      "label": "Progress state text",
      "default": "You have selected <strong>_currentQuantity</strong> of <strong>_requiredQuantity</strong> items",
      "info": "Use _currentQuantity for the current quantity and _requiredQuantity for the required quantity [Learn More](https://shopify.dev/docs)"
    },
    {
      "type": "inline_richtext",
      "id": "summary_end_state_text",
      "label": "End state text",
      "default": "Yay! bundle complete"
    }
  ],
  "presets": [
    {
      "name": "Foxsell M&M Skeleton"
    }
  ]
}
{% endschema %}
