{% liquid
  assign app_namespace = 'app--67872686081'
  assign bundle_product = section.settings.bundle_product
  assign dynamic_add_ons_bundle_config = bundle_product.metafields[app_namespace].dynamic_add_ons_bundle.value
%}

{% if dynamic_add_ons_bundle_config %}
  {% render 'foxsell-skeleton-mix-match', product: bundle_product, section: section %}
{% endif %}

{% schema %}
{
  "name": "FoxSell Skeleton",
  "settings": [
    {
      "type": "product",
      "id": "bundle_product",
      "label": "Bundle product"
    },
    {
      "type": "header",
      "content": "Product grid"
    },
    {
      "type": "select",
      "id": "product_grid_columns_mobile",
      "label": "Mobile",
      "options": [
        { 
          "value": "1", 
          "label": "1" 
        },
        { 
          "value": "2", 
          "label": "2" 
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "product_grid_columns_desktop",
      "label": "Desktop",
      "default": 3,
      "min": 1,
      "max": 5,
      "step": 1
    },
    {
      "type": "range",
      "id": "product_grid_gap",
      "label": "Grid gap",
      "default": 16,
      "min": 0,
      "max": 16,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "hide_category_title",
      "label": "Hide category titles",
      "default": false,
      "info": "Only applies when quantity options (QAO) are enabled."
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "select",
      "id": "product_card_image_aspect_ratio",
      "label": "Image size",
      "options": [
        {
          "value": "original",
          "label": "Original"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "original"
    },
    {
      "type": "checkbox",
      "id": "product_card_secondary_image_on_hover",
      "label": "Show secondary image on hover",
      "default": false
    },
    {
      "type": "select",
      "id": "product_card_options_type",
      "label": "Variant style",
      "options": [
        {
          "value": "radio",
          "label": "Radio"
        },
        {
          "value": "select",
          "label": "Select"
        }
      ],
      "default": "select"
    },
    {
      "type": "checkbox",
      "id": "product_card_show_color_swatches",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "header",
      "content": "Bundle Summary"
    },
    {
      "type": "text",
      "id": "summary_title",
      "label": "Title",
      "default": "My Bundle"
    },
    {
      "type": "inline_richtext",
      "id": "summary_empty_state_text",
      "label": "Empty state text",
      "default": "No items in the bundle yet",
      "info": "Formatting options [Learn more](https://foxsell.notion.site/progress-message-formatting-options)"
    },
    {
      "type": "inline_richtext",
      "id": "summary_progress_state_text",
      "label": "Progress state text",
      "default": "You have selected <strong>_currentQuantity</strong> of <strong>_requiredQuantity</strong> items",
      "info": "Use _currentQuantity for the current quantity and _requiredQuantity for the required quantity [Learn more](https://foxsell.notion.site/progress-message-formatting-options)"
    },
    {
      "type": "inline_richtext",
      "id": "summary_end_state_text",
      "label": "End state text",
      "default": "Yay! bundle complete",
      "info": "Formatting options [Learn more](https://foxsell.notion.site/progress-message-formatting-options)"
    }
  ],
  "presets": [
    {
      "name": "FoxSell Skeleton",
      "settings": {
        "bundle_product": "{{ product }}"
      }
    }
  ]
}
{% endschema %}
