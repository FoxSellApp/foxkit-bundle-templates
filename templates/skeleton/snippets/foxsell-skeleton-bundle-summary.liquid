{% doc %}
  Renders the FoxSell Bundle Summary component.
  @param {section} section - The section that contains the settings for the bundle summary
  @param {object} options - The options for the bundle summary
  @param {string} [view] - The view to render, either 'header' or 'summary'
  @param {string} [header_class] - The class to add to the header
{% enddoc %}

{% liquid
  assign title = section.settings.summary_title
  assign empty_state_text = section.settings.summary_empty_state_text | default: 'No items in the bundle yet'
  assign progress_state_text = section.settings.summary_progress_state_text | default: 'You have selected %s of %s items'
  assign end_state_text = section.settings.summary_end_state_text | default: 'Bundle complete'
%}

{% capture script_config %}
  <script id="foxsell-bundle-progress-config" type="application/json">
    {
      "emptyStateText": {{ empty_state_text | json }},
      "progressStateText": {{ progress_state_text | json }},
      "endStateText": {{ end_state_text | json }}
    }
  </script>
{% endcapture %}

{% case view %}
  {% when 'header' %}
    {% if options.size > 0 %}
      <foxsell-bundle-progress class="{{ header_class }}" data-type="summary-header">
        <div class="foxsell-bundle-progress__header-content">
          <div class="foxsell-bundle-progress__price">
            <div>Price</div>
            <div class="foxsell-bundle-progress__price-value">{{ 0 | money_without_trailing_zeros }}</div>
          </div>
          <div class="foxsell-bundle-progress__list">
            {% for option in options %}
              <div class="foxsell-bundle-progress__item {% if forloop.first %}active{% endif %}" data-id="{{ option.variant_id }}">
                <div class="foxsell-bundle-progress__title">{{ option.title }}</div>
                {% if option.price.strategy == 'dynamic_pricing' %}
                  <div class="foxsell-bundle-progress__value">{{ option.price.value | remove: '.0' }}%</div>
                {% else %}
                  <div class="foxsell-bundle-progress__value">{{ option.price.value | times: 100 | money_without_trailing_zeros }}</div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        </div>
      </foxsell-bundle-progress>
    {% endif %}
  {% else %}
    <foxsell-bundle-summary class="foxsell-bundle-summary">
      <div class="foxsell-bundle-summary__header">
        <div>
          <span>{{ title }}</span>
          <span data-foxsell-total-quantity></span>
        </div>
        <button type="button" class="foxsell-bundle-summary__toggle" id="foxsell-bundle-summary-toggle" aria-expanded="false" aria-controls="foxsell-bundle-summary-panel">
          <span class="foxsell--show">Show</span>
          <span class="foxsell--hide">Hide</span>
        </button>
      </div>
      {% render 'foxsell-skeleton-bundle-summary', section: section, view: 'header', options: options, header_class: 'foxsell-desktop-header' %}
      <foxsell-bundle-progress data-type="progress-bar">
        <div class="foxsell-bundle-progress">
          <div class="foxsell-bundle-progress__label">{{ empty_state_text }}</div>
          <div class="foxsell-bundle-progress__bars">
            {% comment %} Dynamically rendered by updateProgressBar {% endcomment %}
          </div>
          {{ script_config }}
        </div>
      </foxsell-bundle-progress>
      <div class="foxsell-bundle-summary__items-list" id="foxsell-bundle-summary-panel" role="region" aria-label="{{ title | escape }}">
        <p>No items in bundle. Add items to your bundle to see the summary here.</p>
      </div>
    </foxsell-bundle-summary>
{% endcase %}