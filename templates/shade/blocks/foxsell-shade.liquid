{% liquid
  assign app_namespace = 'app--67872686081'
  assign bundle_product = block.settings.bundle_product | default: product
  assign dynamic_add_ons_bundle_config = bundle_product.metafields[app_namespace].dynamic_add_ons_bundle.value
%}

{% if dynamic_add_ons_bundle_config %}
  {% style %}
    .foxsell-mix-match-block {
      padding-top: {{ block.settings.block_padding_top | default: 28 }}px;
      padding-bottom: {{ block.settings.block_padding_bottom | default: 28 }}px;
    }

    @media screen and (min-width: 768px) {
      .foxsell-mix-match-block {
        padding-top: calc({{ block.settings.block_padding_top | default: 28 }}px * 1.5);
        padding-bottom: calc({{ block.settings.block_padding_bottom | default: 28 }}px * 1.5);
      }
    }
  {% endstyle %}
  <div class="foxsell-mix-match-block">{% render 'foxsell-shade-mix-match', product: bundle_product, section: block %}</div>
{% endif %}

{% schema %}
{
  "name": "FoxSell Shade",
  "settings": [
    {
      "type": "product",
      "id": "bundle_product",
      "label": "Bundle product"
    },
    {
      "type": "number",
      "id": "section_base_font_size",
      "label": "Base font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "block_padding_top",
      "label": "Padding top",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "block_padding_bottom",
      "label": "Padding bottom",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "header",
      "content": "Color scheme"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#FFFFFF",
      "info": "Product cards and bundle summary"
    },
    {
      "type": "color",
      "id": "text",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_1",
      "label": "Accent 1",
      "default": "#FFE000"
    },
    {
      "type": "color",
      "id": "accent_text_1",
      "label": "Accent 1 text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_2",
      "label": "Accent 2",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_text_2",
      "label": "Accent 2 text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border",
      "label": "Border",
      "default": "#E0E0E0"
    },
    {
      "type": "header",
      "content": "Border radius"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Images & panels",
      "default": 5,
      "min": 0,
      "max": 25,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Buttons & inputs",
      "default": 5,
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "select",
      "id": "product_card_image_aspect_ratio",
      "label": "Image size",
      "options": [
        {
          "value": "original",
          "label": "Original"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "original"
    },
    {
      "type": "checkbox",
      "id": "product_card_secondary_image_on_hover",
      "label": "Show secondary image on hover",
      "default": false
    },
    {
      "type": "select",
      "id": "product_card_options_type",
      "label": "Variant style",
      "options": [
        {
          "value": "radio",
          "label": "Radio"
        },
        {
          "value": "select",
          "label": "Select"
        }
      ],
      "default": "select"
    },
    {
      "type": "checkbox",
      "id": "product_card_show_color_swatches",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "text",
      "id": "color_option_name",
      "label": "Color option name",
      "default": "Color",
      "info": "The product option name to treat as a color swatch option."
    },
    {
      "type": "textarea",
      "id": "manual_color_swatches",
      "label": "Manual color swatches",
      "info": "Comma-separated option value to hex map. Example: Red: #FF0000, Blue: #0000FF"
    },
    {
      "type": "range",
      "id": "color_swatch_size",
      "label": "Swatch size",
      "default": 20,
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Locale settings"
    },
    {
      "type": "text",
      "id": "add_ons_category_title",
      "label": "Add-ons category title",
      "default": "Add-ons"
    },
    {
      "type": "text",
      "id": "discount_label",
      "label": "Discount label",
      "default": "save _discount%"
    }
  ],
  "presets": [
    {
      "name": "FoxSell Shade"
    }
  ]
}
{% endschema %}