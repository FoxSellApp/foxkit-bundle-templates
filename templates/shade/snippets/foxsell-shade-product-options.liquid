{% doc %}
  Renders the options for a product.

  @param {product} product - The product to be rendered
  @param {object} allowed_variants - The allowed variants for the product
  @param {object} section - The section to be rendered
  @param {string} [type] - The type of options to render, either 'radio' or 'select'
  @param {boolean} [show_color_swatches] - Whether to render color swatches for options that support them
  @param {string} [color_option_name] - The option name to treat as the color swatch option. Defaults to "Color".
  @param {string} [manual_color_swatches] - Comma-separated "OptionValue: #hex" map for manual color swatches
  @param {string} [category] - Category identifier scoping these inputs, used to avoid name collisions when the same product appears in multiple categories

  @example
  {% render 'foxsell-shade-product-options', allowed_variants: allowed_variants, type: 'radio' %}
{% enddoc %}



{% liquid
  assign type = type | default: 'radio'
  assign available_variants = ''
  assign featured_image = null | default: src: product.featured_image.src, width: product.featured_image.width, height: product.featured_image.height, alt: product.featured_image.alt
  assign this_product = null | default: title: product.title, id: product.id, handle: product.handle, featured_image: featured_image, price: product.price
  assign first_available_variant = null
  assign option1_values = ''
  assign option2_values = ''
  assign option3_values = ''

  comment
    Build array of allowed variant IDs for checking
  endcomment
  assign allowed_ids = ''
  for allowed_variant in allowed_variants
    assign variant_id = allowed_variant[0] | split: 'ProductVariant/' | last | times: 1
    unless allowed_ids == blank
      assign allowed_ids = allowed_ids | append: ','
    endunless
    assign allowed_ids = allowed_ids | append: variant_id
  endfor
  assign allowed_ids_array = allowed_ids | split: ','

  paginate product.variants by 250
    for variant in product.variants
      assign variant_id_str = variant.id | append: ''
      if variant.available and allowed_ids_array contains variant_id_str
        unless first_available_variant
          assign first_available_variant = variant
        endunless
        unless available_variants == blank
          assign available_variants = available_variants | append: ','
        endunless
        assign p_variant = variant | json
        comment
          Re-inject inventory fields stripped by Shopify's json filter
        endcomment
        assign inv_suffix = ',"inventory_quantity":' | append: variant.inventory_quantity | append: ',"inventory_policy":"' | append: variant.inventory_policy | append: '"}'
        assign p_variant = p_variant | remove_last: '}' | append: inv_suffix
        assign available_variants = available_variants | append: p_variant

        comment
          Collect all available option values (using exact array matching)
        endcomment
        unless variant.option1 == blank
          assign temp_array = option1_values | split: ','
          unless temp_array contains variant.option1
            unless option1_values == blank
              assign option1_values = option1_values | append: ','
            endunless
            assign option1_values = option1_values | append: variant.option1
          endunless
        endunless
        unless variant.option2 == blank
          assign temp_array = option2_values | split: ','
          unless temp_array contains variant.option2
            unless option2_values == blank
              assign option2_values = option2_values | append: ','
            endunless
            assign option2_values = option2_values | append: variant.option2
          endunless
        endunless
        unless variant.option3 == blank
          assign temp_array = option3_values | split: ','
          unless temp_array contains variant.option3
            unless option3_values == blank
              assign option3_values = option3_values | append: ','
            endunless
            assign option3_values = option3_values | append: variant.option3
          endunless
        endunless
      endif
    endfor
  endpaginate

  assign option1_array = option1_values | split: ','
  assign option2_array = option2_values | split: ','
  assign option3_array = option3_values | split: ','

  assign color_option_name = color_option_name | downcase

  comment
    Normalize manual_color_swatches ("Red: #FF0000, Blue: #0000FF") into a
    "|key:color" lookup string for case-insensitive matching
  endcomment
  assign manual_swatch_map = ''
  assign manual_pairs = manual_color_swatches | split: ','
  for pair in manual_pairs
    assign kv = pair | split: ':'
    if kv.size == 2
      assign pair_key = kv[0] | strip | downcase
      assign pair_color = kv[1] | strip
      assign manual_swatch_map = manual_swatch_map | append: '|' | append: pair_key | append: ':' | append: pair_color
    endif
  endfor
%}

{% capture script_data %}
  <script type="application/json">
    {
      "product": {{ this_product | json }},
      "available_variants": [{{ available_variants }}],
      "allowed_variants": {{ allowed_variants | json }}
    }
  </script>
{% endcapture %}

{% if type == 'radio' %}
<foxsell-variant-radio class="foxsell-variant-radio" data-product-id="{{ product.id }}">
  {% for option in product.options_with_values %}
    {% liquid
      assign swatch_count = option.values | map: 'swatch' | compact | size
      assign option_position = 'option' | append: option.position
      assign option_name_lower = option.name | downcase
      assign show_color_swatch = false
      if show_color_swatches
        if swatch_count > 0
          assign show_color_swatch = true
        elsif option_name_lower == color_option_name
          assign manual_swatch_match_count = 0
          for value in option.values
            assign value_lookup = value | strip | downcase | prepend: '|' | append: ':'
            if manual_swatch_map contains value_lookup
              assign manual_swatch_match_count = manual_swatch_match_count | plus: 1
            endif
          endfor
          if manual_swatch_match_count == option.values.size
            assign show_color_swatch = true
          endif
        endif
      endif
    %}
    <fieldset class="{% if show_color_swatch %}fieldset--color-swatch{% else %}fieldset--radio{% endif %}">
      <legend>{{ option.name }}: <span class="js foxsell-variant-radio__option-value">{{ first_available_variant[option_position] }}</span></legend>
      {% for value in option.values %}
        {% liquid
          assign name = option.name | handleize | append: '-' | append: option.position | append: '-' | append: product.id | append: '-' | append: category
          assign is_available = false
          assign is_checked = false

          assign manual_swatch_color = false
          assign value_lookup = value | strip | downcase | prepend: '|' | append: ':'
          if manual_swatch_map contains value_lookup
            assign manual_swatch_color = manual_swatch_map | split: value_lookup | last | split: '|' | first
          endif
          assign swatch_color = value.swatch.color | default: manual_swatch_color

          assign swatch_color_brightness = swatch_color | color_brightness
          if swatch_color_brightness > 105
            assign swatch_strikethrough_color_mix = '#000'
          else
            assign swatch_strikethrough_color_mix = '#fff'
          endif

          if first_available_variant
            case option.position
              when 1
                if value == first_available_variant.option1
                  assign is_checked = true
                  assign is_available = true
                elsif option1_array contains value
                  assign is_available = true
                endif
              when 2
                if value == first_available_variant.option2
                  assign is_checked = true
                  assign is_available = true
                elsif option2_array contains value
                  assign is_available = true
                endif
              when 3
                if value == first_available_variant.option3
                  assign is_checked = true
                  assign is_available = true
                elsif option3_array contains value
                  assign is_available = true
                endif
            endcase
          endif
        %}
        <label style="--swatch-strikethrough-color-mix: {{ swatch_strikethrough_color_mix }};">
          {% if show_color_swatch %}
            {% if value.swatch.image %}
              <span class="swatch image" style="--swatch-image: url({{ value.swatch.image | image_url: width: 100 }});"></span>
            {% elsif value.swatch.color %}
              <span class="swatch color" style="--swatch-color: {{ value.swatch.color }};"></span>
            {% elsif manual_swatch_color %}
              <span class="swatch color" style="--swatch-color: {{ manual_swatch_color }};"></span>
            {% else %}
              <span>{{ value }}</span>
            {% endif %}
          {% else %}
            <span>{{ value }}</span>
          {% endif %}
          <input
            type="radio"
            name="{{ section.id }}-{{ name }}"
            value="{{ value | escape }}"
            {% if is_checked %}checked{% endif %}
            {% unless is_available %}disabled{% endunless %}
          >
          <svg class="variant-strikethrough" width="100%" height="100%" viewBox="0 0 100 46" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <line x1="100" y1="0" x2="0" y2="46" vector-effect="non-scaling-stroke"></line>
            <line x1="100" y1="0" x2="0" y2="46" vector-effect="non-scaling-stroke"></line>
          </svg>
        </label>
      {% endfor %}
    </fieldset>
  {% endfor %}

  {{ script_data }}
</foxsell-variant-radio>
{% endif %}

{% if type == 'select' %}
<foxsell-variant-select class="foxsell-variant-select" data-product-id="{{ product.id }}" data-first-variant-id="{{ first_available_variant.id }}">
  {% for option in product.options_with_values %}
    {% liquid
      assign swatch_count = option.values | map: 'swatch' | compact | size
      assign option_position = 'option' | append: option.position
      assign option_name_lower = option.name | downcase
      assign show_color_swatch = false
      if show_color_swatches
        if swatch_count > 0
          assign show_color_swatch = true
        elsif option_name_lower == color_option_name
          assign manual_swatch_match_count = 0
          for value in option.values
            assign value_lookup = value | strip | downcase | prepend: '|' | append: ':'
            if manual_swatch_map contains value_lookup
              assign manual_swatch_match_count = manual_swatch_match_count | plus: 1
            endif
          endfor
          if manual_swatch_match_count == option.values.size
            assign show_color_swatch = true
          endif
        endif
      endif
    %}
    <fieldset class="{% if show_color_swatch %}fieldset--color-swatch{% else %}fieldset--select{% endif %}">
      <legend>{{ option.name }}: <span class="js foxsell-variant-select__option-value">{{ first_available_variant[option_position] }}</span></legend>
      {% if show_color_swatch %}
        {% for value in option.values %}
          {% liquid
            assign name = option.name | handleize | append: '-' | append: option.position | append: '-' | append: product.id | append: '-' | append: category
            assign is_available = false
            assign is_checked = false

            assign manual_swatch_color = false
            assign value_lookup = value | strip | downcase | prepend: '|' | append: ':'
            if manual_swatch_map contains value_lookup
              assign manual_swatch_color = manual_swatch_map | split: value_lookup | last | split: '|' | first
            endif
            assign swatch_color = value.swatch.color | default: manual_swatch_color

            assign swatch_color_brightness = swatch_color | color_brightness
            if swatch_color_brightness > 105
              assign swatch_strikethrough_color_mix = '#000'
            else
              assign swatch_strikethrough_color_mix = '#fff'
            endif

            if first_available_variant
              case option.position
                when 1
                  if value == first_available_variant.option1
                    assign is_checked = true
                    assign is_available = true
                  elsif option1_array contains value
                    assign is_available = true
                  endif
                when 2
                  if value == first_available_variant.option2
                    assign is_checked = true
                    assign is_available = true
                  elsif option2_array contains value
                    assign is_available = true
                  endif
                when 3
                  if value == first_available_variant.option3
                    assign is_checked = true
                    assign is_available = true
                  elsif option3_array contains value
                    assign is_available = true
                  endif
              endcase
            endif
          %}
          <label style="--swatch-strikethrough-color-mix: {{ swatch_strikethrough_color_mix }};">
            {% if value.swatch.image %}
              <span class="swatch image" style="--swatch-image: url({{ value.swatch.image | image_url: width: 100 }});"></span>
            {% elsif value.swatch.color %}
              <span class="swatch color" style="--swatch-color: {{ value.swatch.color }};"></span>
            {% elsif manual_swatch_color %}
              <span class="swatch color" style="--swatch-color: {{ manual_swatch_color }};"></span>
            {% else %}
              <span>{{ value }}</span>
            {% endif %}
            <input
              type="radio"
              name="{{ section.id }}-{{ name }}"
              value="{{ value | escape }}"
              {% if is_checked %}checked{% endif %}
              {% unless is_available %}disabled{% endunless %}
            >
            <svg class="variant-strikethrough" width="100%" height="100%" viewBox="0 0 100 46" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
              <line x1="100" y1="0" x2="0" y2="46" vector-effect="non-scaling-stroke"></line>
              <line x1="100" y1="0" x2="0" y2="46" vector-effect="non-scaling-stroke"></line>
            </svg>
          </label>
        {% endfor %}
      {% else %}
        <select name="{{ option.name | handleize | append: '-' | append: option.position | append: '-' | append: product.id | append: '-' | append: category }}" id="{{ option.name | handleize | append: '-' | append: option.position | append: '-' | append: product.id | append: '-' | append: category }}">
          {% for value in option.values %}
            {% liquid
              assign name = option.name | handleize | append: '-' | append: option.position | append: '-' | append: product.id | append: '-' | append: category
              assign is_available = false
              assign is_checked = false

              if first_available_variant
                case option.position
                  when 1
                    if value == first_available_variant.option1
                      assign is_checked = true
                      assign is_available = true
                    elsif option1_array contains value
                      assign is_available = true
                    endif
                  when 2
                    if value == first_available_variant.option2
                      assign is_checked = true
                      assign is_available = true
                    elsif option2_array contains value
                      assign is_available = true
                    endif
                  when 3
                    if value == first_available_variant.option3
                      assign is_checked = true
                      assign is_available = true
                    elsif option3_array contains value
                      assign is_available = true
                    endif
                endcase
              endif
            %}
            <option value="{{ value | escape }}" {% if is_checked %}selected{% endif %}>
              {{ value }} {% unless is_available %}- unavailable{% endunless %}
            </option>
          {% endfor %}
        </select>
      {% endif %}
    </fieldset>
  {% endfor %}

  {{ script_data }}
</foxsell-variant-select>
{% endif %}
