{% doc %}
  Renders a product card for the FoxSell Mix Match.
  @param {product} product - The product to be rendered
  @param {string} category_title - The category title of the product to be rendered
  @param {object} allowed_variants - The allowed variants for the product
  @param {string} image_aspect_ratio - The aspect ratio of the image, either 'original' or 'square'
  @param {object} section - The section to be rendered

  @param {boolean} [show_price] - Whether to show the price of the product
  @param {string} [view] - The view to render, either 'card' or 'modal'
  @param {string} [type] - The type of options to render, either 'radio' or 'select'
  @param {boolean} [show_secondary_image_on_hover] - Card view defaults to false unless passed. Modal view defaults to true unless passed.
  @param {boolean} [show_color_swatches] - Whether to render color swatches for options that support them.
  @param {number} [default_quantity] - The default quantity of the product
  @param {string} [color_option_name] - The option name to treat as the color swatch option. Defaults to "Color".
  @param {string} [manual_color_swatches] - Comma-separated "OptionValue: #hex" map for manual color swatches.
  @param {string} [add_on_strategy] - AddOn strategy of the bundle
  @param {boolean} [add_on_selected_by_default] - Whether the add-on checkbox is checked by default. Defaults to true.

  @example
  {% render 'foxsell-shade-product-card', section: section, view: 'card', product: product %}
{% enddoc %}

{% liquid
  unless show_price == false
    assign show_price = true
  endunless
  assign show_secondary_image_on_hover = show_secondary_image_on_hover | default: false
  unless add_on_selected_by_default == false
    assign add_on_selected_by_default = true
  endunless
  assign quantity = default_quantity | default: 1
  assign image_aspect_ratio = image_aspect_ratio | default: 'original'
  assign image_class = 'js foxsell-product-card__image foxsell--image-' | append: image_aspect_ratio
  unless category_title == '__add_ons__'
    assign category_title = category_title | sha1
  endunless

  assign secondary_image = blank
  if show_secondary_image_on_hover and product.images.size > 1 and product.featured_image
    for image in product.images
      if image.id != product.featured_image.id
        assign secondary_image = image
        break
      endif
    endfor
  endif

  assign image_aspect_ratio_value = product.featured_image.aspect_ratio | default: 1
%}

{% case view %}
  {% when 'modal' %}
    <foxsell-product-card
      class="foxsell-product-card foxsell-product-card--modal"
      data-product-id="{{ product.id }}"
      data-category="{{ category_title }}"
      style="--foxsell-image-aspect-ratio: {{ image_aspect_ratio_value }};"
    >
      <div class="foxsell-product-card__image-wrapper">
        {{ product.featured_image | image_url: width: 500 | image_tag: class: image_class }}
      </div>
      <div class="foxsell-product-card__info">
        <div class="foxsell-product-card__title">{{ product.title }}</div>
        <div>
          {{ product.description }}
        </div>
      </div>
    </foxsell-product-card>
  {% else %}
    <foxsell-product-card
      class="foxsell-product-card"
      data-product-id="{{ product.id }}"
      data-category="{{ category_title }}"
      style="--foxsell-image-aspect-ratio: {{ image_aspect_ratio_value }};"
      data-quantity="{{ quantity }}"
    >
      {% if category_title == '__add_ons__' and add_on_strategy != 'automatic_add' %}
        <label class="foxsell--checkbox">
          <div class="check"></div>
          <input class="foxsell-add-on-checkbox" type="checkbox" name="addon"{% if add_on_selected_by_default %} checked{% endif %}>
        </label>
      {% endif %}
      <div class="foxsell-product-card__image-wrapper" data-open-modal>
        <div class="foxsell-product-card__media">
          {{ product.featured_image | image_url: width: 500 | image_tag: class: image_class }}
          {% if secondary_image != blank %}
            {% assign secondary_image_class = image_class | append: ' foxsell-product-card__image--secondary' %}
            {{ secondary_image | image_url: width: 500 | image_tag: class: secondary_image_class }}
          {% endif %}
        </div>
      </div>
      <div class="foxsell-product-card__info">
        <div class="foxsell-product-card__title-wrapper">
          <div class="foxsell-product-card__title">{{ product.title }}</div>
          {% if category_title != "__add_ons__" and quantity > 1 %}
            <div class="foxsell-product--quantity">x{{ quantity }}</div>
          {% endif %}
        </div>
        {% if show_price %}
          <div class="js foxsell-product-card__price">{{ product.first_available_variant.price | money }}</div>
        {% endif %}
        <div {% if product.has_only_default_variant %}class="foxsell--hidden"{% endif %}>
          {% render 'foxsell-shade-product-options',
            product: product,
            allowed_variants: allowed_variants,
            type: type,
            show_color_swatches: show_color_swatches,
            color_option_name: color_option_name,
            manual_color_swatches: manual_color_swatches,
            section: section,
            category: category_title
          %}
        </div>
      </div>
    </foxsell-product-card>
{% endcase %}
